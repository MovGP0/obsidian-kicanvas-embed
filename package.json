{
  "name": "kicanvas-embed",
  "version": "0.1.0",
  "description": "Render KiCad (https://www.kicad.org/) documents using KiCanvas (https://kicanvas.org/).",
  "main": "main.js",
  "scripts": {
    "prepare:kicanvas": "node scripts/prepare-kicanvas.mjs",
    "build": "npm run prepare:kicanvas && tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "dev": "npm run prepare:kicanvas && node esbuild.config.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "kicad",
    "kicanvas"
  ],
  "author": "Johann Dirry",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "obsidian": "^1.8.10",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  }
}
